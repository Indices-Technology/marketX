generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Profile {
  id                String         @id @db.Uuid
  email             String         @unique
  role              String         @default("user")
  avatar            String?
  username          String?        @unique
  password_hash     String
  created_at        DateTime       @default(now()) @db.Timestamptz(6)
  updated_at        DateTime       @updatedAt @db.Timestamptz(6)
  email_verified_at DateTime?      @db.Timestamptz(6)
  email_verified    Boolean        @default(false)
  bio               String?
  location          String?
  links             Json?
  addresses         Addresses[]    @relation("UserAddress")
  cartItems         CartItem[]
  comments          Comment[]      @relation("UserComments")
  commentLikes      CommentLike[]  @relation("UserCommentLikes")
  conversationsP1   Conversation[] @relation("ConversationP1")
  conversationsP2   Conversation[] @relation("ConversationP2")
  // People I am following (I am the follower)
  following         Follow[]       @relation("UserAsFollower")

  likes             Like[]          @relation("ProfileLikes")
  media             Media[]         @relation("MediaAuthor")
  sentMessages      Message[]       @relation("MessageSender")
  sentNotifications Notification[]  @relation("NotificationFromActor")
  notifications     Notification[]  @relation("NotificationToProfile")
  orders            Orders[]        @relation("BuyerOrders")
  posts             Post[]          @relation("UserPosts")
  savedPosts        SavedPost[]     @relation("UserSavedPosts")
  postLikes         PostLike[]      @relation("UserProfileLikes")
  sellerProfile     SellerProfile[] @relation("SellerProfile")
  shares            Share[]         @relation("ProfileShares")
  stories           Story[]         @relation("UserStories")
  sessions          Session[]       @relation("UserSessions")

  affiliateCode String? @unique

  email_verification EmailVerificationToken[]
  password_reset     PasswordResetToken[]
  audit_logs         AuditLog[]
  user_settings      UserSettings?
  aiConfig           UserAIConfig?
  aiProfile          UserAIProfile?
  affiliateOrders    Orders[]                 @relation("AffiliateOrders")
  reviews            Review[]                 @relation("UserReviews")
  buyerWallet        BuyerWallet?

  // ── Squares ──────────────────────────────────────────────────────────────
  squareOfficerRoles        SquareOfficer[]      @relation("SquareOfficers")
  squareFollows             UserSquareFollow[]   @relation("UserSquareFollows")
  squareMembershipsVerified SquareMembership[]   @relation("SquareMembershipVerifier")
  squarePayoutRequests      SquarePayout[]       @relation("SquarePayoutRequests")
  squareAnnouncements       SquareAnnouncement[] @relation("AnnouncementAuthor")
  squareRequests            SquareRequest[]      @relation("SquareRequestBuyer")
  sellerReviews             SellerReview[]       @relation("SellerReviewAuthor")

  // ── Moderation ────────────────────────────────────────────────────────────
  isActive          Boolean          @default(true)
  strikeCount       Int              @default(0)
  bannedAt          DateTime?        @db.Timestamptz(6)
  suspendedUntil    DateTime?        @db.Timestamptz(6)
  reportsFiled      Report[]         @relation("ReportsFiled")
  reportsModerated  Report[]         @relation("ReportsModerated")
  suspensions       UserSuspension[] @relation("UserSuspensions")
  suspensionsIssued UserSuspension[] @relation("SuspensionsIssued")

  // ── Support ──────────────────────────────────────────────────────────────
  supportTicketsRequested SupportTicket[]  @relation("SupportRequester")
  supportTicketsAssigned  SupportTicket[]  @relation("SupportAgent")
  supportMessages         SupportMessage[] @relation("SupportMessageAuthor")

  @@index([created_at(sort: Desc)]) // admin user list ordering + pagination
  @@index([bannedAt]) // admin banned/active counts + banned filter
}

model SellerProfile {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId             String                 @db.Uuid // ← REMOVED @unique
  store_name            String?
  store_description     String?
  store_logo            String?
  store_banner          String?
  store_location        String?
  store_phone           String?
  store_website         String?
  store_socials         Json?
  followers_count       Int                    @default(0)
  is_verified           Boolean                @default(false)
  is_active             Boolean                @default(true)
  verification_status   VerificationStatus     @default(PENDING)
  verification_reason   String?
  created_at            DateTime               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime               @updatedAt @db.Timestamptz(6)
  store_slug            String                 @unique
  auto_answer_enabled   Boolean                @default(false)
  default_currency      String                 @default("NGN")
  isPremium             Boolean                @default(false)
  // ── Media watermark (reels/video) ─────────────────────────────────────────
  watermark_enabled     Boolean                @default(false)
  watermark_text        String? // null → falls back to store_name at render time
  // Shipping origin — where this store ships from
  shipFromName          String?
  shipFromAddress       String?
  shipFromCity          String?
  shipFromState         String?
  shipFromZip           String?
  shipFromCountry       String                 @default("NG")
  shipFromPhone         String?
  // ── GPS / Discovery ──────────────────────────────────────────────────────
  latitude              Float?
  longitude             Float?
  city                  String?
  state                 String?
  locationLabel         String? // human-readable e.g. "Yaba, Lagos"
  hideLocation          Boolean                @default(false) // ghost mode — hides from map
  lastActiveAt          DateTime?              @db.Timestamptz(6) // updated on dashboard visit — drives online status
  businessHours         Json? // { mon:{open,close,closed}, tue:..., ... } — weekly schedule
  timezone              String                 @default("Africa/Lagos") // IANA timezone for open/closed computation
  // ── Pay on Delivery ──────────────────────────────────────────────────────
  pod_enabled           Boolean                @default(false) // seller opts into POD
  pod_zones             Json? // string[] of eligible state names e.g. ["Lagos","Abuja"]
  pod_delivery_days     Int                    @default(3) // promised delivery window in days
  // ── Bring-your-own-shipping (BYOS) — seller self-delivery config ──────────
  /// SellerShippingConfig JSON: { selfEnabled, flatRateMinor?, freeOverMinor?, pickupEnabled?, pickupNote?, etaText?, zoneRates? }
  shippingConfig        Json?
  // ── Squares ──────────────────────────────────────────────────────────────
  /// Denormalised for fast feed queries — mirrors the SquareMembership where isPrimary = true
  primarySquareId       String?                @db.Uuid
  squareMemberships     SquareMembership[]     @relation("SellerSquareMemberships")
  squareOffers          SquareOffer[]          @relation("SquareOfferSeller")
  media                 Media[]                @relation("MediaSeller")
  products              Products[]             @relation("SellerProducts")
  profile               Profile                @relation("SellerProfile", fields: [profileId], references: [id], onDelete: Cascade)
  wallet                SellerWallet?
  bankAccounts          BankAccount[]
  verificationDocuments VerificationDocument[]
  conversations         Conversation[]         @relation("ConversationSeller")
  sellerReviews         SellerReview[]         @relation("SellerReviews")
  supportTickets        SupportTicket[]        @relation("SupportSeller")
  // ── Rating (denormalised — updated on every review write) ────────────────
  averageRating         Float?
  totalReviews          Int                    @default(0)

  @@unique([profileId, store_slug])
  @@index([profileId])
  @@index([is_active, followers_count(sort: Desc)]) // featured: WHERE is_active=true ORDER BY followers_count DESC
  @@index([created_at(sort: Desc)]) // admin seller list ordering + pagination
}

model Conversation {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @updatedAt @db.Timestamptz(6)
  lastMessageAt DateTime? @db.Timestamptz(6)

  // 1. Participant 1: Always the User (Buyer/Initiator)
  participant1Id String  @db.Uuid
  participant1   Profile @relation("ConversationP1", fields: [participant1Id], references: [id])

  // 2. Participant 2 (Social): Another User
  // Changed to OPTIONAL (?) to support seller chats instead
  participant2Id String?  @db.Uuid
  participant2   Profile? @relation("ConversationP2", fields: [participant2Id], references: [id])

  // 3. Seller Target (Commerce): A Store
  // NEW optional field for store-based chats
  sellerId String?        @db.Uuid
  seller   SellerProfile? @relation("ConversationSeller", fields: [sellerId], references: [id])

  // Context: Optional product link
  currentProductId Int?
  currentProduct   Products? @relation("ConversationProduct", fields: [currentProductId], references: [id])

  messages      Message[]
  notifications Notification[] @relation("NotificationToConversation")

  // Constraints:
  // Ensure a unique chat exists between a User and another User
  @@unique([participant1Id, participant2Id])
  // Ensure a unique chat exists between a User and a Seller
  @@unique([participant1Id, sellerId])
  @@index([participant1Id])
  @@index([sellerId])
}

model Message {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String       @db.Uuid
  senderId       String       @db.Uuid
  content        String
  read           Boolean      @default(false)
  sentAt         DateTime     @default(now()) @db.Timestamptz(6)
  isAiResponse   Boolean      @default(false)
  productId      Int?
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  product        Products?    @relation("ProductMessages", fields: [productId], references: [id])
  sender         Profile      @relation("MessageSender", fields: [senderId], references: [id])
}

model Products {
  id                  Int                 @id @default(autoincrement())
  title               String
  slug                String              @unique
  description         String?
  price               Float
  discount            Float?
  status              ProductStatus?      @default(DRAFT)
  sellerId            String              @db.Uuid
  created_at          DateTime            @default(now()) @db.Timestamptz(6)
  updated_at          DateTime            @updatedAt @db.Timestamptz(6)
  soldCount           Int                 @default(0)
  viewCount           Int                 @default(0)
  cartCount           Int                 @default(0)
  averageRating       Float?
  totalReviews        Int                 @default(0)
  isFeatured          Boolean             @default(false)
  bannerImageUrl      String?
  SKU                 String?             @unique
  isAccessory         Boolean             @default(false)
  store_slug          String
  // embedding      Unsupported("vector")?
  isThrift            Boolean             @default(false)
  affiliateCommission Float?
  socialCaptions      Json?
  // ── Unified Product Post ──────────────────────────────────────────────────
  /// Publish this product into the main social feed as a Post
  showInFeed          Boolean             @default(false)
  /// Publish this product into the Reels surface
  showInReels         Boolean             @default(false)
  /// The auto-created Post record linked to this product (1-to-1)
  linkedPostId        String?             @unique @db.Uuid
  linkedPost          Post?               @relation("ProductLinkedPost", fields: [linkedPostId], references: [id], onDelete: SetNull)
  // ── Deals ──────────────────────────────────────────────────────────────────
  /// True when this product is a time-limited flash deal
  isDeal              Boolean             @default(false)
  /// When the deal expires (null = no expiry / always-on deal)
  dealEndsAt          DateTime?           @db.Timestamptz(6)
  // ── Pre-loved / Thrift ────────────────────────────────────────────────────
  /// Physical condition for pre-loved/thrift items
  condition           String? // NEW_WITH_TAGS | LIKE_NEW | GOOD | FAIR | POOR
  /// The Square this product belongs to — inherited from the seller's primary Square
  squareId            String?             @db.Uuid
  square              Square?             @relation("SquareProducts", fields: [squareId], references: [id], onDelete: SetNull)
  comments            Comment[]
  conversations       Conversation[]      @relation("ConversationProduct")
  likes               Like[]
  media               Media[]
  messages            Message[]           @relation("ProductMessages")
  notifications       Notification[]      @relation("NotificationToProduct")
  category            ProductCategories[] @relation("ProductCategory")
  taggedInPosts       ProductPostTag[]
  appearsIn           ProductRelation[]   @relation("AppearsIn")
  styledWith          ProductRelation[]   @relation("StyledWith")
  tags                ProductTags[]       @relation("ProductTag")
  variants            ProductVariant[]
  offers              ProductOffer[]
  reviews             Review[]            @relation("ProductReviews")
  squareOffers        SquareOffer[]
  seller              SellerProfile       @relation("SellerProducts", fields: [sellerId], references: [id], onDelete: Cascade)
  shares              Share[]             @relation("ProductShare")
  stories             Story[]

  moderationStatus ModerationStatus @default(ACTIVE)
  reportCount      Int              @default(0)

  analytics ProductAnalytics[]

  @@index([sellerId])
  @@index([store_slug, status, created_at(sort: Desc)]) // seller storefront/management grid + countProducts: WHERE store_slug=? [AND status=?] ORDER BY created_at DESC
  @@index([status, created_at(sort: Desc)]) // feed/shop queries: WHERE status='PUBLISHED' ORDER BY created_at DESC
  @@index([status, isDeal, created_at(sort: Desc)]) // shop-today deal filter
  @@index([status, showInFeed, created_at(sort: Desc)]) // home feed product injection
  @@index([status, isThrift, created_at(sort: Desc)]) // pre-loved feed
  @@index([moderationStatus])
}

model ProductAnalytics {
  id            Int      @id @default(autoincrement())
  productId     Int
  storeSlug     String
  date          DateTime @db.Date
  views         Int      @default(0)
  impressions   Int      @default(0)
  orders        Int      @default(0)
  unitsSold     Int      @default(0)
  revenue       Float    @default(0)
  affiliatePaid Float    @default(0)

  product Products @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@index([storeSlug, date])
}

model ProductVariant {
  id         Int         @id @default(autoincrement())
  size       String
  stock      Int
  price      Float?
  productId  Int
  cartItems  CartItem[]
  orderItems OrderItem[]
  product    Products    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
}

/// Volume-discount offer: "Buy X or more, get Y% off"
model ProductOffer {
  id          Int      @id @default(autoincrement())
  productId   Int
  /// Minimum quantity to trigger the offer
  minQuantity Int
  /// Discount percentage (0-100)
  discount    Float
  /// Optional seller-written label shown to buyers
  label       String?
  isActive    Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  product     Products @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Orders {
  id                Int             @id @default(autoincrement())
  userId            String          @db.Uuid
  /// Legacy Stripe reference — now used as generic payment reference
  stripeId          String          @unique
  /// Payment reference (populated after payment init). Shared across all the
  /// per-seller orders of one checkout, so it is NOT unique.
  paymentRef        String?
  /// Groups the per-seller orders created from one checkout/payment.
  purchaseGroupId   String?         @db.Uuid
  /// The chosen shipping option for this seller's parcel { carrier, service, amount, estimatedDays }.
  shippingBreakdown Json?
  paymentStatus     PaymentStatus   @default(UNPAID)
  name              String
  address           String
  zipcode           String
  county            String
  country           String
  /// Destination state (province) — distinct from county (LGA). Carrier station
  /// resolution needs the STATE; captured at checkout, required for GIG booking.
  shipState         String?
  /// Destination contact phone — required by the carrier for delivery.
  shipPhone         String?
  /// Shipping cost in cents
  shippingCost      Int             @default(0)
  shippingZone      String?
  estimatedDays     String?
  totalAmount       Int
  status            OrderStatus     @default(PENDING)
  created_at        DateTime        @default(now()) @db.Timestamptz(6)
  updated_at        DateTime        @updatedAt @db.Timestamptz(6)
  paymentMethod     String
  shipper           String?
  trackingNumber    String?
  /// URL to the shipping label PDF (populated after shipment is created)
  labelUrl          String?
  /// Which shipping provider created this shipment: 'sendbox' | 'shippo'
  shippingProvider  String?
  payoutAmount      Int?
  /// Timestamp when seller marked the order as shipped
  shippedAt         DateTime?
  /// Carrier tracking id / GIG Waybill (set at booking, before handover)
  waybill           String?
  /// How the parcel reaches the carrier: 'PICKUP' (carrier collects) | 'DROPOFF'
  bookingMode       String?
  /// Last normalized carrier tracking status (TrackingStatus), from scan polling
  carrierStatus     String?
  /// When carrierStatus was last refreshed from the carrier
  carrierStatusAt   DateTime?
  /// Set when a carrier scan confirms delivery — gates seller payout release
  deliveredAt       DateTime?
  /// Affiliate who referred this order (if any)
  affiliateUserId   String?         @db.Uuid
  /// Total affiliate cut for this order in cents
  affiliateCut      Int             @default(0)
  notifications     Notification[]  @relation("NotificationToOrder")
  orderItem         OrderItem[]
  user              Profile         @relation("BuyerOrders", fields: [userId], references: [id])
  affiliate         Profile?        @relation("AffiliateOrders", fields: [affiliateUserId], references: [id])
  podDelivery       PodDelivery?
  supportTickets    SupportTicket[] @relation("SupportOrder")

  @@index([paymentRef])
  @@index([purchaseGroupId])
  @@index([userId, created_at(sort: Desc)]) // buyer order list: WHERE userId=X ORDER BY created_at DESC (getUserOrders)
  @@index([paymentStatus, created_at(sort: Desc)]) // admin orders list + revenue aggregate
  @@index([created_at(sort: Desc)]) // admin all-orders list ordering
  @@index([waybill]) // tracking poller: batch-fetch in-flight shipments by waybill
}

/// Pay-on-Delivery lifecycle for a POD order (one per Orders row). Owns the POD
/// state machine + money-in-transit (freight deposit, courier remittance,
/// settlement, denied-delivery refund). See docs/POD.md.
model PodDelivery {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId             Int       @unique
  order               Orders    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  /// 'gig' | 'byop'
  provider            String
  /// POD_TRANSITIONS state machine (docs/POD.md §2)
  state               String    @default("INITIATED")
  /// Buyer's prepaid freight deposit (kobo)
  freightDepositMinor Int
  /// Platform tax withheld from the freight (kobo)
  freightTaxMinor     Int       @default(0)
  /// Product cash the courier collects on delivery (kobo)
  codAmountMinor      Int
  trackingRef         String?
  /// DELIVERED_COLLECTED | ATTEMPT_FAILED | RETURNED
  attemptOutcome      String?
  /// Provider attestation / buyer-confirmation evidence
  attemptProof        Json?
  attemptedAt         DateTime? @db.Timestamptz(6)
  /// BYOP buyer-confirm-or-timeout window for the freight refund
  disputeWindowEndsAt DateTime? @db.Timestamptz(6)
  remittedAmountMinor Int?
  remittedAt          DateTime? @db.Timestamptz(6)
  reconciledAt        DateTime? @db.Timestamptz(6)
  settledAt           DateTime? @db.Timestamptz(6)
  freightRefundedAt   DateTime? @db.Timestamptz(6)
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @updatedAt @db.Timestamptz(6)

  @@index([state])
  @@index([provider, state])
}

/// Support ticket / order dispute. See docs/SUPPORT.md.
model SupportTicket {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Human-facing reference, shown as MX-<n>
  ticketNumber Int               @unique @default(autoincrement())
  type         SupportTicketType @default(SUPPORT)
  category     SupportCategory   @default(OTHER)
  priority     SupportPriority   @default(NORMAL)
  status       SupportStatus     @default(OPEN)
  source       SupportSource     @default(WEB)
  subject      String

  /// Nullable → supports guest / checkout-placeholder buyers (guestEmail set instead)
  requesterId String?  @db.Uuid
  requester   Profile? @relation("SupportRequester", fields: [requesterId], references: [id], onDelete: SetNull)
  guestEmail  String?

  assignedAgentId String?  @db.Uuid
  assignedAgent   Profile? @relation("SupportAgent", fields: [assignedAgentId], references: [id], onDelete: SetNull)

  // ── Context links ──────────────────────────────────────────────────────────
  orderId   Int?
  order     Orders?        @relation("SupportOrder", fields: [orderId], references: [id], onDelete: SetNull)
  productId Int?
  /// Seller counterparty (required for a DISPUTE)
  sellerId  String?        @db.Uuid
  seller    SellerProfile? @relation("SupportSeller", fields: [sellerId], references: [id], onDelete: SetNull)

  // ── Dispute resolution ──────────────────────────────────────────────────────
  resolution     String?
  disputeOutcome DisputeOutcome?
  /// Partial refund amount in cents (PARTIAL_REFUND outcome)
  refundAmount   Int?

  lastMessageAt DateTime? @db.Timestamptz(6)
  resolvedAt    DateTime? @db.Timestamptz(6)
  closedAt      DateTime? @db.Timestamptz(6)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @updatedAt @db.Timestamptz(6)

  messages SupportMessage[] @relation("TicketMessages")

  @@index([status, priority, created_at(sort: Desc)])
  @@index([requesterId, created_at(sort: Desc)])
  @@index([assignedAgentId, status])
  @@index([type, status])
  @@index([orderId])
}

model SupportMessage {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticketId     String            @db.Uuid
  ticket       SupportTicket     @relation("TicketMessages", fields: [ticketId], references: [id], onDelete: Cascade)
  /// Null = SYSTEM message
  authorId     String?           @db.Uuid
  author       Profile?          @relation("SupportMessageAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  authorRole   SupportAuthorRole @default(REQUESTER)
  body         String
  /// [{ url, name }] Cloudinary uploads
  attachments  Json?
  /// Agent-only note, hidden from requester/seller
  internalNote Boolean           @default(false)
  created_at   DateTime          @default(now()) @db.Timestamptz(6)

  @@index([ticketId, created_at])
}

enum SupportTicketType {
  SUPPORT
  DISPUTE
}

enum SupportCategory {
  ORDER
  PAYMENT
  DELIVERY
  ACCOUNT
  SELLER
  PRODUCT
  REFUND
  OTHER
}

enum SupportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportStatus {
  OPEN
  IN_PROGRESS
  PENDING_USER
  RESOLVED
  CLOSED
}

enum SupportSource {
  WEB
  EMAIL
  CHECKOUT
  ORDER
}

enum SupportAuthorRole {
  REQUESTER
  SELLER
  AGENT
  SYSTEM
}

enum DisputeOutcome {
  REFUND_BUYER
  RELEASE_SELLER
  PARTIAL_REFUND
  REJECTED
}

model OrderItem {
  id           Int            @id @default(autoincrement())
  orderId      Int
  quantity     Int
  /// Unit price in cents at time of order
  price        Float          @default(0)
  /// Affiliate cut for this line item in cents
  affiliateCut Int            @default(0)
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  variantId    Int
  order        Orders         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant      ProductVariant @relation(fields: [variantId], references: [id])
}

model CartItem {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quantity   Int
  /// Effective unit price (after discount) at time of add — used to detect price changes
  priceAtAdd Float?
  created_at DateTime       @default(now())
  userId     String         @db.Uuid
  variantId  Int
  user       Profile        @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([userId, variantId])
}

model Addresses {
  id         Int      @id @default(autoincrement())
  userId     String   @db.Uuid
  label      String?
  name       String
  address    String
  county     String
  state      String
  zipcode    String
  country    String
  phone      String
  isDefault  Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
  user       Profile  @relation("UserAddress", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Global platform-level shipping zones (not seller-scoped)
model GlobalShippingZone {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String   @unique
  countries     String[]
  /// Base shipping cost in cents
  baseRate      Int
  /// Additional cost per kg in cents
  perKgRate     Int      @default(0)
  /// e.g. "3-5 business days"
  estimatedDays String
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @updatedAt @db.Timestamptz(6)
}

model BankAccount {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerId      String        @db.Uuid
  bankName      String
  bankCode      String
  accountNumber String
  accountName   String
  isDefault     Boolean       @default(false)
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  seller        SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

model SellerWallet {
  sellerId        String        @unique @db.Uuid
  balance         Float         @default(0)
  pending_balance Float         @default(0)
  updated_at      DateTime      @updatedAt
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payouts         Payout[]
  seller          SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
}

model Transaction {
  walletId    String       @db.Uuid
  amount      Float
  type        String
  orderId     Int?
  description String
  created_at  DateTime     @default(now())
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wallet      SellerWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Payout {
  walletId        String       @db.Uuid
  amount          Float
  status          String
  bank_account    Json
  transaction_ref String?
  requested_at    DateTime     @default(now())
  completed_at    DateTime?
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wallet          SellerWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

/// Wallet for buyers — holds affiliate commissions earned by non-seller users,
/// refunds, and any future buyer-side credits.
model BuyerWallet {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId    String             @unique @db.Uuid
  balance      Float              @default(0)
  updated_at   DateTime           @updatedAt
  profile      Profile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  transactions BuyerTransaction[]
}

model BuyerTransaction {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletId    String      @db.Uuid
  amount      Float
  /// AFFILIATE_CREDIT | REFUND | DEBIT | CREDIT
  type        String
  orderId     Int?
  description String
  created_at  DateTime    @default(now())
  wallet      BuyerWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Story {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authorId   String    @db.Uuid
  productId  Int?
  expiresAt  DateTime
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  viewCount  Int       @default(0)
  mediaId    String    @unique @db.Uuid
  author     Profile   @relation("UserStories", fields: [authorId], references: [id], onDelete: Cascade)
  media      Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  product    Products? @relation(fields: [productId], references: [id])

  @@index([expiresAt]) // active story filter: WHERE expiresAt > NOW()
  @@index([authorId, expiresAt]) // user-specific active stories
}

model Post {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authorId       String           @db.Uuid
  caption        String?
  content        String?
  contentType    String?
  /// JSON array of { type, id, handle, displayName, avatar } — structured @mentions
  mentions       Json?
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  visibility     VisibilityType?  @default(PUBLIC)
  allowComments  Boolean          @default(true)
  viewCount      Int              @default(0)
  /// True when this Post was auto-created from a product (unified product post)
  isProductPost  Boolean          @default(false)
  /// The Square this post belongs to — inherited from the author's primary Square at creation time
  squareId       String?          @db.Uuid
  square         Square?          @relation("SquarePosts", fields: [squareId], references: [id], onDelete: SetNull)
  /// The product this post was generated from (populated when isProductPost = true)
  sourceProduct  Products?        @relation("ProductLinkedPost")
  comments       Comment[]
  notifications  Notification[]
  author         Profile          @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)
  media          Media[]          @relation("PostMedia")
  likes          PostLike[]
  shares         Share[]          @relation("PostShares") // Matches Share model
  taggedProducts ProductPostTag[]
  hashtags       PostTags[]       @relation("PostHashtags")
  savedBy        SavedPost[]      @relation("PostSavedBy")

  moderationStatus ModerationStatus @default(ACTIVE)
  reportCount      Int              @default(0)

  /// Wall target — when set this post is a shoutout on another profile's wall.
  /// wallTargetType: "USER" or "STORE"; wallTargetSlug: username or store_slug.
  wallTargetType String?
  wallTargetSlug String?

  @@index([authorId])
  @@index([created_at(sort: Desc)]) // feed ordering: ORDER BY created_at DESC
  @@index([visibility, created_at(sort: Desc)]) // filtered feed: WHERE visibility='PUBLIC' ORDER BY created_at DESC
  @@index([moderationStatus])
  @@index([wallTargetType, wallTargetSlug, created_at(sort: Desc)]) // wall feed
}

model SavedPost {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  postId    String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  user Profile @relation("UserSavedPosts", fields: [userId], references: [id], onDelete: Cascade)
  post Post    @relation("PostSavedBy", fields: [postId], references: [id], onDelete: Cascade)

  // Safety: A user can't save the same post twice
  @@unique([userId, postId])
  // Index for fast retrieval of a user's collection
  @@index([userId])
}

model Comment {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  text          String
  authorId      String         @db.Uuid
  productId     Int?
  parentId      String?        @db.Uuid
  created_at    DateTime       @default(now()) @db.Timestamptz(6)
  postId        String?        @db.Uuid
  author        Profile        @relation("UserComments", fields: [authorId], references: [id], onDelete: Cascade)
  parent        Comment?       @relation("Replies", fields: [parentId], references: [id], onDelete: NoAction)
  replies       Comment[]      @relation("Replies")
  post          Post?          @relation(fields: [postId], references: [id], onDelete: Cascade)
  product       Products?      @relation(fields: [productId], references: [id], onDelete: Cascade)
  likes         CommentLike[]
  notifications Notification[] @relation("NotificationToComment")

  moderationStatus ModerationStatus @default(ACTIVE)
  reportCount      Int              @default(0)

  @@index([productId, parentId, created_at(sort: Desc)])
  @@index([postId, parentId, created_at(sort: Desc)])
  @@index([authorId])
}

model Like {
  id         Int      @id @default(autoincrement())
  userId     String   @db.Uuid
  productId  Int
  created_at DateTime @default(now())
  product    Products @relation(fields: [productId], references: [id], onDelete: Cascade)
  profile    Profile  @relation("ProfileLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
}

model CommentLike {
  userId     String   @db.Uuid
  commentId  String   @db.Uuid
  created_at DateTime @default(now())
  comment    Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user       Profile  @relation("UserCommentLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
}

model PostLike {
  userId     String   @db.Uuid
  postId     String   @db.Uuid
  created_at DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user       Profile  @relation("UserProfileLikes", fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model Follow {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  followerId    String   @db.Uuid
  followingId   String   @db.Uuid
  followingType String   @default("USER") // "USER" or "SELLER"
  created_at    DateTime @default(now())

  // Only the follower has a strict database-level relationship
  follower Profile @relation("UserAsFollower", fields: [followerId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId, followingType])
  @@index([followerId])
  @@index([followingId])
  @@index([followerId, followingType]) // stories: WHERE followerId=X AND followingType=Y
}

model Share {
  id         Int      @id @default(autoincrement())
  userId     String   @db.Uuid
  productId  Int?
  postId     String?  @db.Uuid
  platform   String? // e.g., 'whatsapp', 'instagram', 'internal'
  shareUrl   String?
  created_at DateTime @default(now())

  // Relations
  product Products? @relation("ProductShare", fields: [productId], references: [id], onDelete: Cascade)
  post    Post?     @relation("PostShares", fields: [postId], references: [id], onDelete: Cascade)
  profile Profile   @relation("ProfileShares", fields: [userId], references: [id], onDelete: Cascade)

  // Remove the strict unique constraint if you want users to share multiple times
  // or keep it if you only want to track unique platform shares per user
  @@index([postId])
  @@index([productId])
}

model Media {
  url        String
  type       MediaType
  productId  Int?
  created_at DateTime       @default(now()) @db.Timestamptz(6)
  sellerId   String?        @db.Uuid
  altText    String?
  metadata   Json?
  public_id  String?        @unique
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authorId   String         @db.Uuid
  author     Profile        @relation("MediaAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  product    Products?      @relation(fields: [productId], references: [id])
  seller     SellerProfile? @relation("MediaSeller", fields: [sellerId], references: [id])
  postId     String?        @db.Uuid
  isBgMusic  Boolean        @default(false)
  post       Post?          @relation("PostMedia", fields: [postId], references: [id], onDelete: Cascade)
  story      Story?

  musicTitle     String?
  musicArtist    String?
  musicSource    String? // e.g., "Free Music Archive"
  musicSourceUrl String?
}

model Category {
  id              Int                 @id @default(autoincrement())
  name            String              @unique
  thumbnailCatUrl String?
  created_at      DateTime            @default(now()) @db.Timestamptz(6)
  updated_at      DateTime            @updatedAt @db.Timestamptz(6)
  slug            String              @unique
  products        ProductCategories[] @relation("ProductCategory")
}

model Tag {
  id         Int           @id @default(autoincrement())
  name       String        @unique
  created_at DateTime      @default(now()) @db.Timestamptz(6)
  updated_at DateTime      @updatedAt @db.Timestamptz(6)
  products   ProductTags[] @relation("ProductTag")
  posts      PostTags[]    @relation("PostHashtagTag")
}

model PostTags {
  postId String @db.Uuid
  tagId  Int
  post   Post   @relation("PostHashtags", fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation("PostHashtagTag", fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model VerificationDocument {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerProfileId String             @db.Uuid
  type            String
  url             String
  status          VerificationStatus @default(PENDING)
  created_at      DateTime           @default(now()) @db.Timestamptz(6)
  updated_at      DateTime           @updatedAt @db.Timestamptz(6)
  sellerProfile   SellerProfile      @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
}

model Notification {
  id             Int              @id @default(autoincrement())
  userId         String           @db.Uuid
  message        String
  type           NotificationType
  read           Boolean          @default(false)
  orderId        Int?
  productId      Int?
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  updated_at     DateTime         @updatedAt @db.Timestamptz(6)
  actorId        String?          @db.Uuid
  commentId      String?          @db.Uuid
  postId         String?          @db.Uuid
  conversationId String?          @db.Uuid
  actor          Profile?         @relation("NotificationFromActor", fields: [actorId], references: [id])
  comment        Comment?         @relation("NotificationToComment", fields: [commentId], references: [id])
  conversation   Conversation?    @relation("NotificationToConversation", fields: [conversationId], references: [id])
  order          Orders?          @relation("NotificationToOrder", fields: [orderId], references: [id])
  post           Post?            @relation(fields: [postId], references: [id], onDelete: Cascade)
  product        Products?        @relation("NotificationToProduct", fields: [productId], references: [id])
  profile        Profile          @relation("NotificationToProfile", fields: [userId], references: [id])

  @@index([userId])
}

model ProductCategories {
  productId  Int
  categoryId Int
  category   Category @relation("ProductCategory", fields: [categoryId], references: [id], onDelete: Cascade)
  product    Products @relation("ProductCategory", fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model ProductTags {
