  tagId     Int
  product   Products @relation("ProductTag", fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag      @relation("ProductTag", fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

model ProductRelation {
