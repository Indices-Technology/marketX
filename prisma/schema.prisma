  @@index([user_id])
  @@index([token])
}

model PasswordResetToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token      String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  // Relations
  user Profile @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token])
}

model Session {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @db.Uuid
  refreshToken String    @unique
  ip           String?
  userAgent    String?
  device       String?
  country      String?
  expiresAt    DateTime
  lastUsedAt   DateTime  @default(now()) @db.Timestamptz(6)
  revokedAt    DateTime?
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  user         Profile   @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
}

// ==================== USER SETTINGS ====================
model UserSettings {
  user_id             String   @id @db.Uuid
  email_notifications Boolean  @default(true)
  push_notifications  Boolean  @default(true)
  private_profile     Boolean  @default(false)
  two_factor_enabled  Boolean  @default(false)
  language            String   @default("en")
  currency            String   @default("NGN")
  theme               String   @default("system")
  text_size           String   @default("medium")
  auto_mute           Boolean  @default(true)
  compact_feed        Boolean  @default(false)
  show_captions       Boolean  @default(true)
  show_like_counts    Boolean  @default(true)
  show_near_me        Boolean  @default(true)
  show_shop_today     Boolean  @default(true)
  show_stories        Boolean  @default(false)
  reduce_motion       Boolean  @default(false)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  // Relations
  user Profile @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Review {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId  Int
  authorId   String   @db.Uuid
  orderId    Int?
  rating     Int // 1-5
  title      String?
  body       String?
  verified   Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  product Products @relation("ProductReviews", fields: [productId], references: [id], onDelete: Cascade)
  author  Profile  @relation("UserReviews", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([productId, authorId])
  @@index([productId])
  @@index([authorId])
}

/// A buyer's review of a seller store (not a specific product).
/// Gated on at least one completed order from that seller.
model SellerReview {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerId   String   @db.Uuid
  authorId   String   @db.Uuid
  orderId    Int?
  rating     Int // 1-5
  title      String?
  body       String?
  verified   Boolean  @default(true) // always true — gated on completed order
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  seller SellerProfile @relation("SellerReviews", fields: [sellerId], references: [id], onDelete: Cascade)
  author Profile       @relation("SellerReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([sellerId, authorId])
  @@index([sellerId])
  @@index([authorId])
}

// ==================== SQUARES ====================

/// A Square is a named community of sellers — either anchored to a real
/// physical market (Computer Village, Balogun, Bodija) or a category-based
/// cluster for online-first sellers. It is the primary discovery and feed
/// surface in MarketX.
model Square {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String       @unique // "Computer Village Square"
  slug        String       @unique // "computer-village"
  description String?
  type        SquareType   @default(CATEGORY)
  status      SquareStatus @default(PENDING)

  // Branding
  bannerUrl   String?
  iconUrl     String?
  accentColor String? // hex — allows per-square UI theming

  // Geographic data (GEOGRAPHIC squares only)
  latitude        Float?
  longitude       Float?
  city            String?
  state           String?
  country         String  @default("NG")
  physicalAddress String?

  // Association financial config — how much of GMV goes to the association
  associationCutPercent Float @default(0.5)

  // Denormalised counters — updated by the service layer on membership/follow changes
  memberCount   Int @default(0)
  followerCount Int @default(0)
  postCount     Int @default(0)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  officers      SquareOfficer[]
  memberships   SquareMembership[]
  followers     UserSquareFollow[]
  wallet        SquareWallet?
  transactions  SquareTransaction[]
  posts         Post[]               @relation("SquarePosts")
  products      Products[]           @relation("SquareProducts")
  announcements SquareAnnouncement[]
  requests      SquareRequest[]

  @@index([type, status])
  @@index([city, state])
}

/// An association officer — a Profile granted a governance role within a Square.
/// The Chairman has full control; Secretary handles day-to-day operations;
/// Treasurer sees financials; Govt Rep is read-only.
model SquareOfficer {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  squareId    String            @db.Uuid
  profileId   String            @db.Uuid
  role        SquareOfficerRole
  appointedAt DateTime          @default(now()) @db.Timestamptz(6)
  appointedBy String?           @db.Uuid // profileId of the officer who appointed them

  square  Square  @relation(fields: [squareId], references: [id], onDelete: Cascade)
  profile Profile @relation("SquareOfficers", fields: [profileId], references: [id], onDelete: Cascade)

  // One person holds one role per Square (can be changed, not doubled up)
  @@unique([squareId, profileId])
  @@index([squareId])
  @@index([profileId])
}

/// Tracks which sellers belong to which Squares, and whether the membership
/// is their primary identity (isPrimary = true) or a secondary Square for
/// additional feed exposure (isPrimary = false).
/// Rules: one primary per seller, max two secondary (Category Squares only).
model SquareMembership {
  id            String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  squareId      String                 @db.Uuid
  sellerId      String                 @db.Uuid
  isPrimary     Boolean                @default(false)
  status        SquareMembershipStatus @default(PENDING)
  verifiedById  String?                @db.Uuid // Profile who approved the membership
  joinedAt      DateTime               @default(now()) @db.Timestamptz(6)
  suspendedAt   DateTime?              @db.Timestamptz(6)
  suspendReason String?

  square     Square        @relation(fields: [squareId], references: [id], onDelete: Cascade)
  seller     SellerProfile @relation("SellerSquareMemberships", fields: [sellerId], references: [id], onDelete: Cascade)
  verifiedBy Profile?      @relation("SquareMembershipVerifier", fields: [verifiedById], references: [id])

  @@unique([squareId, sellerId])
  @@index([squareId, status])
  @@index([sellerId])
}

/// A buyer or user following a Square — drives their personalised home feed.
model UserSquareFollow {
  userId     String   @db.Uuid
  squareId   String   @db.Uuid
  followedAt DateTime @default(now()) @db.Timestamptz(6)

  user   Profile @relation("UserSquareFollows", fields: [userId], references: [id], onDelete: Cascade)
  square Square  @relation(fields: [squareId], references: [id], onDelete: Cascade)

  @@id([userId, squareId])
  @@index([userId])
  @@index([squareId])
}

/// The association's earnings wallet. Accumulates a cut of every completed
/// order from sellers in the Square. Association officers can request payouts.
model SquareWallet {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  squareId       String   @unique @db.Uuid
  balance        Float    @default(0) // available for withdrawal
  totalEarned    Float    @default(0) // all-time gross earnings
  totalWithdrawn Float    @default(0)
  updated_at     DateTime @updatedAt

  square       Square              @relation(fields: [squareId], references: [id], onDelete: Cascade)
  transactions SquareTransaction[]
  payouts      SquarePayout[]
}

/// One record per completed order that involved a seller in a Square.
/// Captures the cut percentage at the time of the transaction so historical
/// records are accurate even if the rate changes later.
model SquareTransaction {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  squareId     String   @db.Uuid
  walletId     String   @db.Uuid
  orderId      Int
  sellerAmount Float // order value used to compute the cut
  cutPercent   Float // associationCutPercent at time of transaction
  cutAmount    Float // actual amount credited to the wallet
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  square Square       @relation(fields: [squareId], references: [id])
  wallet SquareWallet @relation(fields: [walletId], references: [id])

  @@index([squareId])
  @@index([orderId])
}

/// A payout request from a Square association (initiated by Chairman or Treasurer).
model SquarePayout {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletId       String    @db.Uuid
  amount         Float
  status         String    @default("PENDING") // PENDING | COMPLETED | FAILED
  bankAccount    Json // snapshot of account details at time of payout
  transactionRef String?
  requestedAt    DateTime  @default(now()) @db.Timestamptz(6)
  completedAt    DateTime? @db.Timestamptz(6)
  requestedById  String    @db.Uuid // Chairman or Treasurer who triggered this

  wallet      SquareWallet @relation(fields: [walletId], references: [id])
  requestedBy Profile      @relation("SquarePayoutRequests", fields: [requestedById], references: [id])

  @@index([walletId])
}

/// A broadcast message posted by a Square officer to all members and followers.
model SquareAnnouncement {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  squareId   String   @db.Uuid
  authorId   String   @db.Uuid
  title      String
  body       String
  isPinned   Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  square Square  @relation(fields: [squareId], references: [id], onDelete: Cascade)
  author Profile @relation("AnnouncementAuthor", fields: [authorId], references: [id])

  @@index([squareId, created_at(sort: Desc)])
  @@index([squareId, isPinned])
}

/// A buyer's structured "looking for" request posted into a Square. Sellers in
/// the Square respond with SquareOffers (an existing product). The buyer's
/// contact is never exposed — completion happens on-platform via checkout.
model SquareRequest {
  id                     String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  squareId               String              @db.Uuid
  buyerId                String              @db.Uuid
  categoryId             Int?
  title                  String // ≤80, validated in Zod; may be masked by content guard
  budgetMin              Int? // kobo
  budgetMax              Int? // kobo
  condition              String? // NEW_WITH_TAGS | LIKE_NEW | GOOD | FAIR | POOR | null = any
  sizeSpec               String?
  deliverTo              String? // state / area for shipping feasibility
  note                   String? // ≤300, content-guard masked
  referencePhotoUrl      String?
  visibility             String              @default("square") // square | followed | public
  respondersOnlyVerified Boolean             @default(false)
  isAnonymous            Boolean             @default(false)
  status                 SquareRequestStatus @default(OPEN)
  expiresAt              DateTime            @db.Timestamptz(6)
  created_at             DateTime            @default(now()) @db.Timestamptz(6)
  updated_at             DateTime            @updatedAt @db.Timestamptz(6)

  square Square        @relation(fields: [squareId], references: [id], onDelete: Cascade)
  buyer  Profile       @relation("SquareRequestBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  offers SquareOffer[]

  @@index([squareId, status])
  @@index([buyerId])
  @@index([expiresAt])
}

/// A seller's response to a SquareRequest — always an existing product, never
/// free contact. The buyer accepts one, which routes them to on-platform checkout.
model SquareOffer {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId  String            @db.Uuid
  sellerId   String            @db.Uuid
  productId  Int
  variantId  Int?
  message    String? // ≤200, content-guard masked
  status     SquareOfferStatus @default(PENDING)
  created_at DateTime          @default(now()) @db.Timestamptz(6)

  request SquareRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  seller  SellerProfile @relation("SquareOfferSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  product Products      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([requestId, sellerId, productId]) // one offer per product per seller per request
  @@index([requestId])
}

enum SquareRequestStatus {
  OPEN
  FULFILLED
  EXPIRED
  CLOSED
}

enum SquareOfferStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum SquareType {
  GEOGRAPHIC // anchored to a real physical market e.g. Computer Village
  CATEGORY // online-first / dispersed sellers e.g. Ankara & Fabrics
}

enum SquareStatus {
  PENDING // registered, awaiting admin activation
  ACTIVE // live and visible
  SUSPENDED // temporarily disabled
}

enum SquareOfficerRole {
  CHAIRMAN // full admin — approvals, finances, announcements
  SECRETARY // operational — onboarding, membership management
  TREASURER // financial read — sees earnings and withdrawals
  MODERATOR // content — can flag/remove posts in the square
  GOVT_REP // read-only observer for regulatory purposes
}

enum SquareMembershipStatus {
  PENDING // seller applied, awaiting officer approval
  ACTIVE // approved and active
  SUSPENDED // membership suspended
  REJECTED // request explicitly denied by officer
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  CANCELED
  PAID
  SHIPPED
  DELIVERED
  RETURNED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
  SHIPPING_PAID // POD: shipping fee paid upfront, product amount due on delivery
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum NotificationType {
  ORDER
  REVIEW
  PRODUCT
  GENERAL
  NEW_COMMENT
  COMMENT_LIKE
  REPLY
  PRODUCT_SHARE
  NEW_FOLLOWER
  NEW_POST
  POST_LIKE
  MENTION
  SQUARE_ANNOUNCEMENT
  SQUARE_MEMBERSHIP_APPROVED
  SQUARE_MEMBERSHIP_REJECTED
  SQUARE_REQUEST
  SQUARE_OFFER
  WALL_SHOUTOUT
  SUPPORT
}

enum VisibilityType {
  PUBLIC
  PRIVATE
  FOLLOWERS
}

// ==================== MODERATION ====================

enum ModerationStatus {
  ACTIVE
  FLAGGED
  UNDER_REVIEW
  HIDDEN
  REMOVED
}

enum ReportReason {
  SPAM
  INAPPROPRIATE
  COUNTERFEIT
  HARASSMENT
  MISINFORMATION
  VIOLENCE
  OTHER
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum ContentType {
  POST
  PRODUCT
  COMMENT
  REVIEW
  SELLER_REVIEW
  USER
  STORY
}

enum ModerationAction {
  WARN
  HIDE
  REMOVE
  SUSPEND
  BAN
  REINSTATE
  DISMISS
}

model Report {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporterId    String            @db.Uuid
  contentType   ContentType
  contentId     String
  reason        ReportReason
  note          String?
  status        ReportStatus      @default(PENDING)
  moderatorId   String?           @db.Uuid
  moderatorNote String?
  action        ModerationAction?
  createdAt     DateTime          @default(now()) @db.Timestamptz(6)
  resolvedAt    DateTime?         @db.Timestamptz(6)

  reporter  Profile  @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  moderator Profile? @relation("ReportsModerated", fields: [moderatorId], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([contentType, contentId])
  @@index([reporterId])
}

model UserSuspension {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @db.Uuid
  moderatorId String    @db.Uuid
  reason      String
  expiresAt   DateTime? @db.Timestamptz(6) // null = permanent ban
  liftedAt    DateTime? @db.Timestamptz(6) // set when admin lifts early
  liftedById  String?   @db.Uuid
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)

  user      Profile @relation("UserSuspensions", fields: [userId], references: [id], onDelete: Cascade)
  moderator Profile @relation("SuspensionsIssued", fields: [moderatorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ── AI Model Configuration (BYOM — Bring Your Own Model) ─────────────────────

model UserAIConfig {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId String   @unique @db.Uuid
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  provider  String // 'anthropic' | 'openai'
  model     String // e.g. 'claude-sonnet-4-6', 'gpt-4o'
  apiKey    String // AES-256-GCM encrypted — never returned to clients
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("user_ai_config")
}

// ── AI / RAG ──────────────────────────────────────────────────────────────────

/// Vector embedding for every indexed entity (PRODUCT | SELLER | SQUARE).
/// `embedding` uses Prisma's Unsupported type so Prisma tracks the column without
/// trying to serialize/deserialize it. All vector reads/writes use $queryRaw / $executeRaw.
model Embedding {
  id          String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType  String // PRODUCT | SELLER | SQUARE
  entityId    String // source PK cast to string
  /// Denormalised snapshot used at query time: name, imageUrl, price, slug, location, …
  metadata    Json
  /// SHA-256 of the source text — indexer skips re-embedding when unchanged
  contentHash String
  /// pgvector column — read/write via $queryRaw / $executeRaw only
  embedding   Unsupported("vector(1536)")?
  indexedAt   DateTime                     @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime                     @updatedAt @db.Timestamptz(6)

  @@unique([entityType, entityId])
  @@index([entityType])
  @@index([updatedAt])
}

/// Persistent AI profile for each user.
/// Built from explicit preferences ("I'm size 43") and inferred signals (purchase history).
/// Injected into every Dassah turn so the model knows the user before they say anything.
model UserAIProfile {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @unique @db.Uuid
  /// { height, weight, shoeSize, clothingSize, waist, chest }
  measurements Json?
  /// { style, budget, brands, colors, occasions, preferredSellers }
  preferences  Json?
  /// { topCategories, priceRange, preferredLocations, lastSearches }
  signals      Json?
  rawContext   String?  @db.Text
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Every Dassah AI conversation turn — powers intent analytics, token cost, p95 latency.
/// userId is a plain string (no FK) so logs survive user deletion.
model AiTurnLog {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @db.Uuid
  sessionId         String
  channel           String // dassai-web | dassai-seller-web
  intent            String?
  userMessage       String   @db.Text
  assistantResponse String   @db.Text
  toolsCalled       String[]
  ragHits           Int      @default(0)
  tokensPrompt      Int      @default(0)
  tokensCompletion  Int      @default(0)
  latencyMs         Int      @default(0)
  modelUsed         String?
  guardBlocked      Boolean  @default(false)
  createdAt         DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId])
  @@index([createdAt])
  @@index([channel, createdAt])
  @@index([intent, createdAt])
}

/// Every guard rail trigger — prompt injections, PII, unauthorised tool calls, rate limits.
/// userId is a plain string (no FK) so events survive user deletion.
model GuardRailEvent {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @db.Uuid
  type          String // PROMPT_INJECTION | PII_DETECTED | UNAUTHORIZED_TOOL | RATE_LIMIT
  inputFragment String?  @db.Text
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId])
  @@index([type, createdAt])
}
